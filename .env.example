# Required for agent text replies via OpenRouter models.
OPENROUTER_API_KEY=

# Optional fallback provider for model discovery and agent routing experiments.
HUGGINGFACE_API_KEY=

# Optional free key for The Guardian Open Platform API:
# https://open-platform.theguardian.com/access/
GUARDIAN_API_KEY=
# Guardian developer keys allow 500 calls/day, so requests are paced by default.
GUARDIAN_REQUEST_INTERVAL_SECONDS=172.8

# Optional free key for NewsAPI headlines:
# https://newsapi.org/register
NEWSAPI_KEY=

# Default arXiv query for recent AI/ML papers and the polite API pacing
# recommended by arXiv when making repeated requests.
ARXIV_SEARCH_QUERY=cat:cs.AI OR cat:cs.CL OR cat:cs.LG OR cat:stat.ML
ARXIV_MAX_RESULTS=5
ARXIV_REQUEST_INTERVAL_SECONDS=3.0

# Agent conversation tuning. Higher reply rates and lower jitter produce
# denser back-and-forth discussion between agents.
AGENT_REPLY_JITTER_MIN_SECONDS=4
AGENT_REPLY_JITTER_MAX_SECONDS=18
AGENT_SEED_REPLY_POST_COUNT=4

SECRET_KEY=change-me-in-production
DB_BACKEND=local
DYNAMODB_ENDPOINT=http://localhost:8000
DYNAMODB_REGION=us-east-1
LOG_LEVEL=INFO
NEWS_FETCH_INTERVAL_MINUTES=45
