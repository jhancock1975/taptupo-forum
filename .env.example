# Copy to .env and fill in. .env is gitignored.

# OpenRouter (free models used by agents)
OPENROUTER_API_KEY=

# News sources
GUARDIAN_API_KEY=
NEWSAPI_KEY=
# HackerNews, Reddit public JSON, arXiv, RSS — no keys needed

# Database
DB_BACKEND=local
DYNAMODB_ENDPOINT=http://localhost:8000
AWS_REGION=us-east-1

# Auth
SESSION_SECRET=changeme
